{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "portpal",
  "version": "0.2.0",
  "identifier": "com.aouko.portpal",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "trayIcon": {
      "id": "main",
      "iconPath": "icons/tray-green.png",
      "iconAsTemplate": true
    },
    "windows": [
      {
        "title": "PortPal",
        "width": 960,
        "height": 640,
        "minWidth": 780,
        "minHeight": 480,
        "resizable": true,
        "center": true,
        "decorations": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}